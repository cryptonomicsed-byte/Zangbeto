use crate::zangbeto_client::{ZangbetoClient, ZangbetoPayload};
use omo_diagnostic::{Diagnostic, Severity, Category, RepairStrategy};
use tokio::sync::mpsc;
use tracing::{info, warn, error};

pub struct DiagnosticHandler {
    zangbeto: ZangbetoClient,
    diag_tx: mpsc::Sender<Diagnostic>,
    auto_merge_threshold: Severity,
    security_categories: u8, // bitmask: Security|Identity
}

impl DiagnosticHandler {
    pub fn new(
        zangbeto: ZangbetoClient,
        diag_tx: mpsc::Sender<Diagnostic>,
        auto_merge_threshold: Severity,
    ) -> Self {
        Self {
            zangbeto,
            diag_tx,
            auto_merge_threshold,
            security_categories: Category::as_bitmask(&[Category::Security, Category::Identity]),
        }
    }

    /// Main entry: parse stderr line → route → act
    pub async fn handle_line(&self, line: &str) -> Result<HandlerAction, omo_diagnostic::DiagnosticError> {
        // 1. Parse canonical JSON
        let diag: Diagnostic = serde_json::from_str(line)
            .map_err(|e| omo_diagnostic::DiagnosticError::SchemaInvalid(e.to_string()))?;

        // 2. Forward to heartbeat engine for Red/Blue routing
        self.diag_tx.send(diag.clone()).await
            .map_err(|_| omo_diagnostic::DiagnosticError::SchemaInvalid("Channel closed".into()))?;

        // 3. If security/identity category, require Zangbeto verification before trust
        if (diag.diagnostic.category & self.security_categories) != 0 {
            info!("🔐 Security diagnostic: awaiting Zangbeto verification");
            let hash = diag.compute_message_hash();
            let payload = ZangbetoPayload::from_diagnostic(&diag, &hash);
            let receipt = self.zangbeto.submit_diagnostic(payload).await
                .map_err(|e| omo_diagnostic::DiagnosticError::AnchorFailed(e.to_string()))?;
            
            // Verify signature before trusting
            if !self.zangbeto.verify_signature(&receipt.receipt_id, &receipt.zangbeto_sig).await? {
                return Err(omo_diagnostic::DiagnosticError::SignatureInvalid);
            }
            
            Ok(HandlerAction::VerifiedOnChain(receipt))
        } else {
            // Non-security: can proceed with local repair if strategy=auto
            Ok(HandlerAction::LocalRepairEligible)
        }
    }

    /// Safety gate: should this diagnostic be auto-merged?
    pub fn should_auto_merge(&self, diag: &Diagnostic) -> bool {
        // Rule 1: severity must be <= threshold
        if diag.diagnostic.severity as u8 > self.auto_merge_threshold as u8 {
            return false;
        }
        // Rule 2: security/identity categories always require human gate
        if (diag.diagnostic.category & self.security_categories) != 0 {
            return false;
        }
        // Rule 3: repair strategy must be auto
        if let Some(ref plan) = diag.repair {
            plan.strategy == RepairStrategy::Auto
        } else {
            false
        }
    }
}

pub enum HandlerAction {
    VerifiedOnChain(crate::zangbeto_client::ZangbetoReceipt),
    LocalRepairEligible,
    EscalateToHuman,
}
