        birth_epoch: u64,
        tier: u8,                  // 1=apprentice, 2=adept, 3=master
        sabbath_active: bool,
        // Repair plan reference
        repair_id: vector<u8>,
        repair_strategy: u8,       // 1=auto, 2=manual, 3=hybrid
        // Lifecycle state
        status: u8,                // pending|verified|disputed|fixed|risk_accepted
        fixed_at: Option<u64>,     // epoch when marked fixed
        // Audit trail
        zangbeto_sig: vector<u8>,  // Ed25519 signature of hash(code||message_hash||agent_id)
        arweave_tx: Option<vector<u8>>,
        ots_proof: Option<vector<u8>>,
        submitted_at: u64,
        // Heartbeat tracking
        red_team_round: Option<u64>,
    }

    // ─────────────────────────────────────────────────────
    // Schema Validation (Merged + Bitmask-Safe)
    // ─────────────────────────────────────────────────────
    public fun validate_schema(
        code: &vector<u8>,
        severity: u8,
        category: u8,
        message_hash: &vector<u8>,
        agent_id: &vector<u8>,
    ): bool {
        // 1. Code format
        if (!vector::starts_with(code, &CODE_PREFIX)) { return false };
        if (vector::length(code) > MAX_CODE_LEN) { return false };
        
        // 2. Severity range
        if (severity > SEV_ERROR) { return false };
        
        // 3. Category bitmask: must be subset of VALID_CATEGORIES
        if ((category | VALID_CATEGORIES) != VALID_CATEGORIES) { return false };
        
        // 4. Message hash is SHA-256 length
        if (vector::length(message_hash) != SHA256_LEN) { return false };
        
        // 5. Agent ID is valid address length (32 bytes for Sui)
        if (vector::length(agent_id) < 32) { return false };
        
        true
    }

    public fun has_category(category: u8, flag: u8): bool {
        (category & flag) == flag
    }

