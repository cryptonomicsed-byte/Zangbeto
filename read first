module zangbeto::zbt_core {
    use std::vector;
    use std::option::{Self, Option};
    use sui::object::{Self, UID};
    use sui::tx_context::{Self, TxContext};
    use sui::table::{Self, Table};
    use sui::clock::Clock;
    use sui::transfer;
    use zangbeto::zbt_diagnostics::{Self as diag, DiagnosticReceipt};
    use zangbeto::zbt_errors;
    use zangbeto::zbt_guard;

    // ─────────────────────────────────────────────────────
    // Typed Diagnostic Ledger with Indexing
    // ─────────────────────────────────────────────────────
    struct DiagnosticLedger has key {
        id: UID,
        // receipt_id -> DiagnosticReceipt
        table: Table<vector<u8>, DiagnosticReceipt>,
        // agent_id -> list of receipt_ids
        agent_index: Table<vector<u8>, vector<vector<u8>>>,
        // category_bit -> list of receipt_ids (for analytics)
        category_index: Table<u8, vector<vector<u8>>>,
        // red_team_round -> list of receipt_ids (for heartbeat tracking)
        round_index: Table<u64, vector<vector<u8>>>,
    }

    // ─────────────────────────────────────────────────────
    // Reputation & Bounty Tracking
    // ─────────────────────────────────────────────────────
    struct AgentReputation has key, store {
        id: UID,
        agent_id: vector<u8>,
        birth_epoch: u64,
        total_receipts: u64,
        fixed_count: u64,
        disputed_count: u64,
        bounty_balance: u64,
        last_active: u64,
    }

    struct ReputationLedger has key {
        id: UID,
        table: Table<vector<u8>, AgentReputation>,
    }

    // ─────────────────────────────────────────────────────
    // Initialization (One-Time Setup)
    // ─────────────────────────────────────────────────────
    public entry fun init(ctx: &mut TxContext) {
        let diag_ledger = DiagnosticLedger {
            id: object::new(ctx),
            table: table::new(),
            agent_index: table::new(),
            category_index: table::new(),
            round_index: table::new(),
        };
        transfer::share_object(diag_ledger);

        let rep_ledger = ReputationLedger {
            id: object::new(ctx),
            table: table::new(),
        };
        transfer::share_object(rep_ledger);
    }

    // ─────────────────────────────────────────────────────
    // Submit Diagnostic to Typed Ledger (Canonical Entry)
    // ─────────────────────────────────────────────────────
    public entry fun submit_diagnostic(
        ledger: &mut DiagnosticLedger,
        ctx: &mut TxContext,
        code: vector<u8>,
        severity: u8,
        category: u8,
        message_hash: vector<u8>,
        agent_id: vector<u8>,
        birth_epoch: u64,
        tier: u8,
        sabbath_active: bool,
        repair_id: vector<u8>,
        repair_strategy: u8,
        red_team_round: Option<u64>,
    ) {
        // Validate schema (bitmask-safe)
        assert!(diag::validate_schema(&code, severity, category, &message_hash, &agent_id), zbt_errors::E_SCHEMA_INVALID);
        
        // Create receipt via diagnostics module
        let receipt = diag::emit_diagnostic(
            ctx, code, severity, category, message_hash, agent_id,
            birth_epoch, tier, sabbath_active, repair_id, repair_strategy, red_team_round
        );
        let receipt_id = object::uid_to_inner(&receipt.id);

        // Index by agent
        let mut agent_receipts = if table::contains(&ledger.agent_index, &agent_id) {
            table::remove(&mut ledger.agent_index, &agent_id)
        } else {
            vector::empty()
        };
        vector::push_back(&mut agent_receipts, receipt_id);
        table::add(&mut ledger.agent_index, agent_id, agent_receipts);

        // Index by category bitmask (iterate bits)
        let mut bit = 1;
        while (bit <= 32) {
            if ((category & bit) == bit) {
                let mut cat_receipts = if table::contains(&ledger.category_index, &bit) {
                    table::remove(&mut ledger.category_index, &bit)
                } else {
                    vector::empty()
                };
                vector::push_back(&mut cat_receipts, receipt_id);
                table::add(&mut ledger.category_index, bit, cat_receipts);
            };
            bit = bit << 1;
        };

        // Index by red_team_round (if present)
        if (option::is_some(&red_team_round)) {
            let round = *option::borrow(&red_team_round);
            let mut round_receipts = if table::contains(&ledger.round_index, &round) {
                table::remove(&mut ledger.round_index, &round)
            } else {
                vector::empty()
            };
            vector::push_back(&mut round_receipts, receipt_id);
            table::add(&mut ledger.round_index, round, round_receipts);
        };

        // Store receipt in main table
        table::add(&mut ledger.table, receipt_id, receipt);

        // Emit event for off-chain listeners
        zbt_guard::emit_diagnostic_submitted_event(receipt_id, code, severity, category, agent_id, repair_id, red_team_round, ctx);
    }

    // ─────────────────────────────────────────────────────
    // Query Helpers (Efficient Lookups)
    // ─────────────────────────────────────────────────────
    public fun query_by_agent(
        ledger: &DiagnosticLedger,
        agent_id: vector<u8>,
        category_mask: Option<u8>,
        limit: u64,
    ): vector<DiagnosticReceipt> {
        let mut results = vector::empty();
        if (!table::contains(&ledger.agent_index, &agent_id)) { return results };
        
        let receipt_ids = table::borrow(&ledger.agent_index, &agent_id);
        let mut count = 0;
        let mut i = 0;
        
        while (i < vector::length(receipt_ids) && count < limit) {
            let rid = *vector::borrow(receipt_ids, i);
            let receipt = table::borrow(&ledger.table, &rid);
            let cat_match = match &category_mask {
                Option::Some(mask) => (receipt.category & *mask) != 0,
                Option::None() => true,
            };
            if (cat_match) {
                vector::push_back(&mut results, *receipt);
                count = count + 1;
            };
            i = i + 1;
        };
        results
    }

    public fun query_by_round(
        ledger: &DiagnosticLedger,
        round: u64,
        limit: u64,
    ): vector<DiagnosticReceipt> {
        let mut results = vector::empty();
        if (!table::contains(&ledger.round_index, &round)) { return results };
        
        let receipt_ids = table::borrow(&ledger.round_index, &round);
        let mut count = 0;
        let mut i = 0;
        
        while (i < vector::length(receipt_ids) && count < limit) {
            let rid = *vector::borrow(receipt_ids, i);
            vector::push_back(&mut results, *table::borrow(&ledger.table, &rid));
            count = count + 1;
            i = i + 1;
        };
        results
    }

    // ─────────────────────────────────────────────────────
    // Reputation Management
    // ─────────────────────────────────────────────────────
    public entry fun register_agent(
        rep_ledger: &mut ReputationLedger,
        agent_id: vector<u8>,
        birth_epoch: u64,
        ctx: &mut TxContext,
    ) {
        if (!table::contains(&rep_ledger.table, &agent_id)) {
            let rep = AgentReputation {
                id: object::new(ctx),
                agent_id,
                birth_epoch,
                total_receipts: 0,
                fixed_count: 0,
                disputed_count: 0,
                bounty_balance: 0,
                last_active: tx_context::epoch(ctx),
            };
            table::add(&mut rep_ledger.table, agent_id, rep);
        };
    }

    public entry fun award_bounty(
        rep_ledger: &mut ReputationLedger,
        agent_id: vector<u8>,
        amount: u64,
        ctx: &mut TxContext,
    ) {
        if (table::contains(&rep_ledger.table, &agent_id)) {
            let rep = table::borrow_mut(&mut rep_ledger.table, &agent_id);
            rep.bounty_balance = rep.bounty_balance + amount;
            rep.last_active = tx_context::epoch(ctx);
        };
    }

    // ─────────────────────────────────────────────────────
    // Mark Fixed + Update Reputation (Atomic)
    // ─────────────────────────────────────────────────────
    public entry fun mark_fixed_and_reward(
        diag_ledger: &mut DiagnosticLedger,
        rep_ledger: &mut ReputationLedger,
        receipt_id: vector<u8>,
        fixer_agent: vector<u8>,
        bounty_amount: u64,
        ctx: &mut TxContext,
    ) {
        assert!(table::contains(&diag_ledger.table, &receipt_id), zbt_errors::E_RECEIPT_NOT_FOUND);
        
        // Update receipt status
        let receipt = table::borrow_mut(&mut diag_ledger.table, &receipt_id);
        assert!(receipt.status == diag::STATUS_PENDING || receipt.status == diag::STATUS_VERIFIED, zbt_errors::E_INVALID_TRANSITION);
        receipt.status = diag::STATUS_FIXED;
        receipt.fixed_at = option::some(tx_context::epoch(ctx));
        
        // Update reputation
        if (table::contains(&rep_ledger.table, &fixer_agent)) {
            let rep = table::borrow_mut(&mut rep_ledger.table, &fixer_agent);
            rep.fixed_count = rep.fixed_count + 1;
            rep.bounty_balance = rep.bounty_balance + bounty_amount;
            rep.last_active = tx_context::epoch(ctx);
        };
        
        zbt_guard::emit_fixed_event(receipt_id, fixer_agent, bounty_amount, ctx);
    }
}
